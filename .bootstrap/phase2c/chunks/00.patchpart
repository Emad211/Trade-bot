diff --git a/configs/phase2c_btc_4h.yaml b/configs/phase2c_btc_4h.yaml
new file mode 100644
index 0000000..8b9898c
--- /dev/null
+++ b/configs/phase2c_btc_4h.yaml
@@ -0,0 +1,49 @@
+market:
+  symbol: BTC/USD
+  timeframe: 4h
+  periods_per_year: 2190
+data:
+  source_latency_seconds: 30.0
+  require_regular_bars: true
+  drop_incomplete_last_bar: true
+strategy:
+  ema_fast: 20
+  ema_slow: 100
+  donchian_entry: 40
+  donchian_exit: 20
+  atr_window: 14
+  volatility_window: 30
+  max_annualized_volatility: 1.20
+features:
+  return_windows: [1, 2, 6, 24]
+  volatility_windows: [6, 24, 42]
+  volume_window: 30
+labels:
+  execution_delay_bars: 1
+  holding_period_bars: 1
+  positive_threshold_bps: 0.0
+evaluation:
+  initial_train: 2500
+  calibration_size: 360
+  validation_size: 360
+  test_size: 360
+  step_size: 360
+  embargo: 2
+  thresholds: [0.50, 0.55, 0.60, 0.65]
+  min_entries: 3
+  drawdown_penalty: 0.5
+  cost_multipliers: [1.0, 1.5, 2.0]
+ml:
+  models: [prior, ridge_logistic, lightgbm, catboost]
+  random_seed: 42
+  ridge_c: 1.0
+risk:
+  target_annualized_volatility: 0.35
+  max_exposure: 0.35
+  min_exposure: 0.05
+costs:
+  fee_bps: 15.0
+  slippage_bps: 10.0
+backtest:
+  initial_cash: 10000.0
+  min_history_bars: 150
diff --git a/configs/phase2c_sources.yaml b/configs/phase2c_sources.yaml
new file mode 100644
index 0000000..e21f3f3
--- /dev/null
+++ b/configs/phase2c_sources.yaml
@@ -0,0 +1,44 @@
+schema_version: "1.0"
+timeframe: 4h
+start: 2023-01-01T00:00:00Z
+end: 2026-07-12T20:00:00Z
+as_of: 2026-07-13T00:15:00Z
+spot_required_count: 2
+source_latency_seconds: 30.0
+derivative_latency_seconds: 60.0
+page_limit: 1000
+max_pages: 100
+cross_venue_tolerance_hours: 8.0
+spot_sources:
+  - exchange_id: coinbase
+    symbol: BTC/USD
+  - exchange_id: bitstamp
+    symbol: BTC/USD
+  - exchange_id: gemini
+    symbol: BTC/USD
+derivative_sources:
+  - exchange_id: okx
+    symbol: BTC/USDT:USDT
+  - exchange_id: bybit
+    symbol: BTC/USDT:USDT
+  - exchange_id: binanceusdm
+    symbol: BTC/USDT:USDT
+  - exchange_id: deribit
+    symbol: BTC/USD:BTC
+minimum_derivative_features: 1
+fred_series:
+  - series_id: NASDAQCOM
+    feature_name: nasdaq_composite
+    release_lag_hours: 24
+    source_latency_seconds: 300
+    tolerance_day